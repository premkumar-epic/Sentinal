# ============================================================
# SENTINAL v2 — Environment Configuration
# Copy to .env and customize:  cp .env.example .env
# ============================================================

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Authentication (CHANGE FOR PRODUCTION) ---
AUTH_USERNAME=admin
# Default password: 'sentinal' — generate new hash:
#   python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your-password'))"
AUTH_PASSWORD_HASH=$2b$12$x37lhM/Khg6Yli1gFgEmDeMhLjPWCfj55jCnY33CLdE8NCDDBR35u
# Generate secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
# If left as default, a random key is generated per session (tokens won't survive restarts).
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_MINUTES=1440

# --- Models ---
YOLO_MODEL=yolo11l.pt
YOLO_CONF=0.45
YOLO_IOU=0.50
REID_MODEL=osnet_ain_x1_0_msmt17_256x128_amsgrad_ep50_lr0.0015_coslr_b64_fb10_softmax_labsmth_flip_jitter.pth
REID_THRESHOLD=0.62
FACE_MODEL=buffalo_l
FACE_QUALITY_THRESHOLD=0.6
FACE_MATCH_THRESHOLD=0.68
TRACKER_DEVICE=cuda

# --- Paths ---
MODELS_DIR=models/
SNAPSHOTS_DIR=data/snapshots/
ZONES_FILE=data/zones.json
LOGS_DIR=data/logs/

# --- Database ---
# SQLite (default — zero setup):
DB_URL=sqlite:///data/sentinal.db
# PostgreSQL (production):
# DB_URL=postgresql+asyncpg://sentinal:your_password@localhost/sentinal

# --- Performance Tuning ---
PIPELINE_PROCESS_EVERY_N=3
PIPELINE_REID_EVERY_N=3
PIPELINE_FACE_EVERY_N=5
YOLO_IMGSZ=480
MJPEG_JPEG_QUALITY=70

# --- Alerts ---
ALERT_COOLDOWN_SECONDS=60

# Email (optional)
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_SMTP_HOST=smtp.example.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_SENDER=sentinal@example.com
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_RECIPIENT=admin@example.com

# Webhook (optional)
ALERT_WEBHOOK_ENABLED=false
ALERT_WEBHOOK_URL=

# Telegram (optional)
ALERT_TELEGRAM_ENABLED=false
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# --- Anomaly Thresholds ---
LOITERING_SECONDS=30
CROWD_THRESHOLD=5
VIOLENCE_VELOCITY_THRESHOLD=0.4
VIOLENCE_PROXIMITY_THRESHOLD=1.2

# --- Stream ---
STREAM_FPS_TARGET=15
STREAM_RECONNECT_ERROR_THRESHOLD=5

# --- Startup Cameras (optional, JSON array) ---
# STARTUP_CAMERAS=[{"cam_id":"cam_0","url":"http://192.168.1.x:8080/video","label":"Front Door"}]
STARTUP_CAMERAS=
